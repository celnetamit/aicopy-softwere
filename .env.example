# Core runtime
MANUSCRIPT_EDITOR_ENV=development
MANUSCRIPT_EDITOR_HOST=127.0.0.1
MANUSCRIPT_EDITOR_PORT=8000
PORT=8000
DATA_DIR=./data
DATABASE_URL=

# Auth
GOOGLE_CLIENT_ID=
ALLOWED_EMAIL_DOMAINS=celnet.in,conwiz.in,stmjournals.in,stmjournals.com,nanoschool.in,nstc.in
ADMIN_EMAILS=amit@conwiz.in,puneet.mehrotra@celnet.in
SESSION_TTL_HOURS=12

# Local manual login (development only)
MANUSCRIPT_EDITOR_LOCAL_LOGIN=0
MANUSCRIPT_EDITOR_LOCAL_LOGIN_USERNAME=admin
MANUSCRIPT_EDITOR_LOCAL_LOGIN_PASSWORD=change-this-password
MANUSCRIPT_EDITOR_DEV_TEST_TOKENS=0

# Security and request controls
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
MAX_UPLOAD_BYTES=10485760
MAX_TEXT_CHARS=500000
TASK_LIST_LIMIT_MAX=200
AUTH_RATE_LIMIT_COUNT=20
AUTH_RATE_LIMIT_WINDOW_SECONDS=300
WRITE_RATE_LIMIT_COUNT=120
WRITE_RATE_LIMIT_WINDOW_SECONDS=300

# Processing
PROCESSING_JOB_WORKERS=2
FILE_RETENTION_DAYS=30

# AI provider environment fallbacks
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OPENROUTER_HTTP_REFERER=
OPENROUTER_APP_TITLE=Manuscript Editor
AGENT_ROUTER_TOKEN=
SERPER_API_KEY=

# Ollama transport tuning
MANUSCRIPT_EDITOR_OLLAMA_GENERATE_TIMEOUT_SECONDS=60
MANUSCRIPT_EDITOR_OLLAMA_HEALTH_TIMEOUT_SECONDS=5
MANUSCRIPT_EDITOR_OLLAMA_RETRY_COUNT=0
MANUSCRIPT_EDITOR_OLLAMA_RETRY_BACKOFF_SECONDS=0
MANUSCRIPT_EDITOR_OLLAMA_FALLBACK_MODEL_RETRY=true
